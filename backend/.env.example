# ==============================================================
# P2P UPI Payment Gateway - Backend Environment Variables
# Copy this file to `.env` and fill in the real values.
# ==============================================================

# ---- App ----
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
APP_NAME=P2P-UPI-Gateway
FRONTEND_ADMIN_URL=http://localhost:5173
FRONTEND_TRADER_URL=http://localhost:5174
FRONTEND_MERCHANT_URL=http://localhost:5175
FRONTEND_CHECKOUT_URL=http://localhost:5176

# ---- MySQL Database ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=p2p_upi_gateway
DB_USER=root
DB_PASSWORD=
DB_DIALECT=mysql
DB_LOGGING=false
DB_POOL_MAX=10
DB_POOL_MIN=0

# ---- Redis (cache + BullMQ) ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- JWT Authentication ----
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Security ----
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# ---- WebSocket ----
WS_PATH=/socket.io
WS_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# ---- BullMQ Queues ----
QUEUE_PREFIX=p2p
QUEUE_CONCURRENCY=5

# ---- Payment / UPI Provider (placeholders) ----
UPI_PROVIDER_BASE_URL=
UPI_PROVIDER_API_KEY=
UPI_PROVIDER_WEBHOOK_SECRET=
PAYMENT_CALLBACK_URL=http://localhost:4000/api/v1/webhooks/payment

# ---- Logging ----
LOG_LEVEL=info
LOG_DIR=logs
